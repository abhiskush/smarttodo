{
  "files": [
    "out/",
    "src/webview/",
    "images/"
  ],
  "name": "smarttodo",
  "publisher": "abhiskush",
  "repository": {
    "type": "git",
    "url": "https://github.com/abhiskush/smarttodo.git"
  },
  "icon": "images/logo.ico",
  "displayName": "SmartTodo",
  "description": "A powerful todo management extension with sorting, filtering, and smart management",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "todo",
    "task",
    "productivity",
    "management",
    "list"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:smarttodo.openPanel"
  ],
  "contributes": {
    "commands": [
      {
        "command": "smarttodo.openPanel",
        "title": "SmartTodo: Open Todo List"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
